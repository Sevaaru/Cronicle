<?xml version="1.0" encoding="utf-8"?>
<!-- Previsualización grande 4x4: cabecera + 4 filas con portada y progreso. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_library_background"
    android:padding="12dp"
    android:orientation="vertical">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/widget_library_title"
        android:textColor="@color/widget_on_surface"
        android:textSize="14sp"
        android:textStyle="bold"
        android:paddingBottom="8dp" />

    <include layout="@layout/widget_library_item" />
    <include layout="@layout/widget_library_item" />
    <include layout="@layout/widget_library_item" />
    <include layout="@layout/widget_library_item" />
</LinearLayout>
