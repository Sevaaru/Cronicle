<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@drawable/widget_library_item_background"
    android:padding="10dp"
    android:layout_marginBottom="6dp">

    <!-- Poster cover (or kind badge fallback) -->
    <FrameLayout
        android:layout_width="48dp"
        android:layout_height="64dp">

        <ImageView
            android:id="@+id/widget_item_poster"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:adjustViewBounds="true"
            android:background="@drawable/widget_poster_placeholder"
            android:contentDescription="@string/widget_library_title" />

        <TextView
            android:id="@+id/widget_item_kind"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|start"
            android:layout_margin="2dp"
            android:paddingStart="5dp"
            android:paddingEnd="5dp"
            android:paddingTop="1dp"
            android:paddingBottom="1dp"
            android:background="@drawable/widget_kind_badge_background"
            android:textColor="@color/widget_on_primary"
            android:textSize="9sp"
            android:textStyle="bold"
            android:text="—" />
    </FrameLayout>

    <!-- Title + progress block -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="8dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/widget_item_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/widget_on_surface"
            android:textSize="14sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/widget_item_progress_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="@color/widget_on_surface_variant"
            android:textSize="11sp"
            android:maxLines="1"
            android:ellipsize="end" />

        <ProgressBar
            android:id="@+id/widget_item_progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:layout_marginTop="6dp"
            android:max="100"
            android:progress="0"
            android:progressDrawable="@drawable/widget_progress_drawable" />
    </LinearLayout>

    <!-- +1 button -->
    <ImageButton
        android:id="@+id/widget_item_plus"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="@drawable/widget_plus_background"
        android:src="@drawable/widget_ic_plus"
        android:contentDescription="@string/widget_library_increment"
        android:scaleType="centerInside" />
</LinearLayout>
